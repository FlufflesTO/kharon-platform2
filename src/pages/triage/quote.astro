---
import BaseLayout from '../../layouts/BaseLayout.astro';
import QuoteForm from '../../components/forms/QuoteForm.astro';

const error = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="Engineering Consultation"
  description="Submit a structured intake for new systems, upgrades, and integration planning."
>
  <section class="kharon-container py-20">
    <h1 class="text-5xl font-bold">Engineering Consultation</h1>
    <p class="mt-4 max-w-2xl text-slate-600">
      Use this route for new builds, system upgrades, CAD planning, and integration review.
    </p>

    {error && (
      <div class="mt-6 max-w-2xl border border-red-300 bg-red-50 p-4 text-sm font-bold text-red-700">
        Submission failed. Please check your details and try again, or contact us directly.
      </div>
    )}

    <div class="mt-10 max-w-2xl">
      <QuoteForm />
    </div>
  </section>
</BaseLayout>
