---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MaintenanceForm from '../../components/forms/MaintenanceForm.astro';

const error = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="Maintenance Audit"
  description="Submit a lifecycle maintenance, PPM, or compliance audit request."
>
  <section class="kharon-container py-20">
    <h1 class="text-5xl font-bold">Maintenance Audit</h1>
    <p class="mt-4 max-w-2xl text-slate-600">
      Use this route for PPM scheduling, lifecycle validation, and audit preparation.
    </p>

    {error && (
      <div class="mt-6 max-w-2xl border border-red-300 bg-red-50 p-4 text-sm font-bold text-red-700">
        Submission failed. Please check your details and try again, or contact us directly.
      </div>
    )}

    <div class="mt-10 max-w-2xl">
      <MaintenanceForm />
    </div>
  </section>
</BaseLayout>
