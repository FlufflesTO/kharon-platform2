---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EmergencyForm from '../../components/forms/EmergencyForm.astro';

const error = Astro.url.searchParams.get('error');
---

<BaseLayout
  title="Emergency SLA Callout"
  description="Submit urgent system failure and operational risk escalation details."
>
  <section class="kharon-container py-20">
    <h1 class="text-5xl font-bold text-red-700">Emergency SLA Callout</h1>
    <p class="mt-4 max-w-2xl text-slate-600">
      This route is reserved for urgent failure impact and technical escalation.
    </p>

    {error && (
      <div class="mt-6 max-w-2xl border border-red-300 bg-red-50 p-4 text-sm font-bold text-red-700">
        Submission failed. Please check your details and try again, or call us directly.
      </div>
    )}

    <div class="mt-10 max-w-2xl">
      <EmergencyForm />
    </div>
  </section>
</BaseLayout>
