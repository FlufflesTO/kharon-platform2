---
import { getEntry, render } from 'astro:content';
import EnvironmentLayout from '../../layouts/EnvironmentLayout.astro';

const { slug } = Astro.params;
const entry = slug ? await getEntry('environments', slug) : null;
if (!entry) return Astro.redirect('/404');

const { Content } = await render(entry);

const standards = await Promise.all(
  entry.data.governingStandards.map((standard) => getEntry(standard))
);

const solutions = await Promise.all(
  entry.data.requiredSolutions.map((solution) => getEntry(solution))
);
---

<EnvironmentLayout entry={entry} standards={standards} solutions={solutions}>
  <Content />
</EnvironmentLayout>
