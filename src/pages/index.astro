---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Engineered Fire & Security Systems"
  description="Kharon designs and maintains compliant fire, suppression, and security systems."
>
  <section class="kharon-container py-24">
    <h1 class="text-5xl font-bold">
      Engineered systems. Enforced compliance.
    </h1>

    <p class="mt-6 max-w-2xl text-slate-600">
      Kharon aligns system design, risk, compliance, and lifecycle into a single operational model.
    </p>

    <a href="/triage" class="mt-8 inline-block bg-red-700 px-6 py-3 font-bold text-white">
      Start Triage
    </a>
  </section>
</BaseLayout>