---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Internal Login" description="Kharon internal access">
  <section class="kharon-container py-20">
    <div class="mx-auto max-w-md border border-slate-200 bg-white p-8">
      <h1 class="text-3xl font-bold">Internal Access</h1>
      <p class="mt-3 text-slate-600">Enter the internal access token.</p>

      <form method="post" action="/api/auth/login" class="mt-6 space-y-4">
        <input name="token" type="password" required class="w-full border border-slate-300 p-3" placeholder="Access token" />
        <button class="w-full bg-blue-700 px-4 py-3 font-bold text-white">Sign in</button>
      </form>
    </div>
  </section>
</BaseLayout>
