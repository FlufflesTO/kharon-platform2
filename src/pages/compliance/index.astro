---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const standards = await getCollection('standards');
---

<BaseLayout title="Compliance" description="SANS standards mapped to system design, risk, and liability.">
  <section class="kharon-container py-20">
    <h1 class="text-5xl font-bold">Compliance Matrix</h1>
    <p class="mt-4 max-w-2xl text-slate-600">Every system is governed by enforceable standards. This matrix exposes requirements, risks, and liability.</p>
    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {standards.map((standard) => (
        <article class="border border-[var(--color-line)] bg-white p-6">
          <p class="text-sm font-bold text-blue-700">{standard.data.code}</p>
          <h2 class="mt-2 text-xl font-bold">{standard.data.title}</h2>
          <p class="mt-3 text-sm text-slate-600">{standard.data.mandate}</p>
          <div class="mt-4 space-y-2 text-sm">
            <p><span class="font-bold">Requirement:</span> {standard.data.requirement}</p>
            <p><span class="font-bold">Risk:</span> {standard.data.operationalRisk}</p>
            <p><span class="font-bold">Liability:</span> {standard.data.liability}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
