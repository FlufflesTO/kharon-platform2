---
import { company } from '../../data/company';
---

<footer class="border-t border-[var(--color-line)] bg-gray-950 text-white">
  <div class="kharon-container grid gap-8 py-12 md:grid-cols-3">
    <div>
      <h2 class="font-bold">KHARON</h2>
      <p class="mt-4 text-sm text-gray-300">{company.address.street}, {company.address.locality}, {company.address.postalCode}</p>
      <p class="mt-3 text-sm text-gray-300">Servicing South Africa, Botswana, and Malawi.</p>
    </div>

    <div>
      <h2 class="font-bold">Solutions</h2>
      <a href="/solutions/fire-detection" class="mt-4 block text-sm text-gray-300">Fire Detection</a>
      <a href="/solutions/gas-suppression" class="mt-2 block text-sm text-gray-300">Gas Suppression</a>
      <a href="/solutions" class="mt-2 block text-sm text-gray-300">All Solutions</a>
    </div>

    <div>
      <h2 class="font-bold">Triage</h2>
      <a href="/triage/emergency" class="mt-4 block text-sm font-bold text-red-500">Emergency SLA Callout</a>
      <a href="/triage/quote" class="mt-2 block text-sm text-gray-300">Engineering Consultation</a>
      <a href="/triage/maintenance" class="mt-2 block text-sm text-gray-300">Maintenance Audit</a>
    </div>
  </div>
</footer>
